{
  "rules": {
    "users": {
      ".read": "auth != null",
      ".indexOn": ["profile/usernameLower", "profile/emailLower"],
      "$uid": {
        "profile": {
          ".read": "auth != null",
          ".write": "auth != null && (auth.uid === $uid || $uid === 'bot_assistant')"
        },
        "blocked": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "rooms": {
      ".read": "auth != null",
      "$roomId": {
        ".write": "auth != null && (data.exists() ? data.child('members').child(auth.uid).val() === true : newData.child('members').child(auth.uid).val() === true)"
      }
    },
    "messages": {
      "$roomId": {
        ".read": "auth != null && root.child('rooms').child($roomId).child('members').child(auth.uid).val() === true",
        "$messageId": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('members').child(auth.uid).val() === true && ((!data.exists() && (newData.child('senderId').val() === auth.uid || newData.child('senderId').val() === 'bot_assistant')) || (data.exists() && data.child('senderId').val() === auth.uid))",
          "reactions": {
            "$emoji": {
              "$uid": {
                ".write": "auth != null && auth.uid === $uid && root.child('rooms').child($roomId).child('members').child(auth.uid).val() === true"
              }
            }
          },
          "updatedAt": {
            ".write": "auth != null && root.child('rooms').child($roomId).child('members').child(auth.uid).val() === true"
          }
        }
      }
    }
  }
}